# =============================================================================
# App Config Root — Bootstrap-Packer cascade
# =============================================================================
# Copy this tree next to your App bootstrap and strip the ".example" suffix
# from every file (including this one -> .env). Loaded by
# BuildDomainKernelFromEnv via DotEnv::loadPrivate() (load()/load?() cascade).
# =============================================================================

load(.env.database)
load?(.env.redis)
load?(.env.cache)
load?(.env.logger)
load?(.env.http)
load?(.env.mail)
