# =============================================================================
# CACHE CONFIGURATION — BuildCacheFromEnv (requires jardisadapter/cache)
# =============================================================================
# Comma-separated layer list, tried in this order (write-through, first hit wins):
# memory | apcu | redis | db
#
# redis needs .env.redis; db needs an active DB connection (.env.database).
# =============================================================================

CACHE_LAYERS=memory
CACHE_NAMESPACE=app

# -----------------------------------------------------------------------------
# db layer table name (defaults to "cache" if unset)
# -----------------------------------------------------------------------------
#CACHE_DB_TABLE=cache

# -----------------------------------------------------------------------------
# Example: multi-layer with Redis + Database fallback
# -----------------------------------------------------------------------------
#CACHE_LAYERS=memory,redis,db
