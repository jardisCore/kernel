# =============================================================================
# LOGGING CONFIGURATION — BuildLoggerFromEnv (requires jardisadapter/logger)
# =============================================================================
# Comma-separated handler[:LEVEL] list. LEVEL defaults to LOG_LEVEL if omitted.
# Available handler types:
#   file | console | errorlog | syslog | browserconsole | redis
#   slack | teams | loki | webhook | null
#
# redis needs .env.redis (shared fan-out, D4).
# =============================================================================

LOG_HANDLERS=console:DEBUG
LOG_CONTEXT=app
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# file handler
# -----------------------------------------------------------------------------
#LOG_HANDLERS=file:ERROR
#LOG_FILE_PATH=/var/log/app.log

# -----------------------------------------------------------------------------
# Network handlers (URL unset -> handler is skipped, no error)
# -----------------------------------------------------------------------------
#LOG_HANDLERS=slack:ERROR
#LOG_SLACK_URL=https://hooks.slack.com/services/...

#LOG_HANDLERS=teams:ERROR
#LOG_TEAMS_URL=https://outlook.office.com/webhook/...

#LOG_HANDLERS=loki:INFO
#LOG_LOKI_URL=http://loki:3100

#LOG_HANDLERS=webhook:ERROR
#LOG_WEBHOOK_URL=https://api.example.com/logs

# -----------------------------------------------------------------------------
# Multiple handlers combined
# -----------------------------------------------------------------------------
#LOG_HANDLERS=console:DEBUG,file:ERROR,slack:ERROR
