# =============================================================================
# MAILER CONFIGURATION — BuildMailerFromEnv (requires jardisadapter/mailer)
# =============================================================================
# MAIL_HOST unset -> mailer stays null, no error.
# =============================================================================

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TIMEOUT=30
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=App
