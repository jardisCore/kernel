#HTTP_VERIFY_SSL=true
#HTTP_BEARER_TOKEN=
#HTTP_BASIC_USER=
#HTTP_BASIC_PASSWORD=
#HTTP_MAX_RETRIES=0
#HTTP_RETRY_DELAY_MS=100
