# =============================================================================
# REDIS CONNECTION — shared fan-out (BuildRedisFromEnv, D4)
# =============================================================================
# One Redis connection, built once, feeds BOTH the cache "redis" layer
# (.env.cache) AND the logger "redis" handler (.env.logger). No separate
# per-consumer Redis config exists — set it once here.
# =============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
#REDIS_PASSWORD=
#REDIS_DATABASE=0
