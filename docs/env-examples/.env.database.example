# =============================================================================
# DATABASE CONFIGURATION — BuildConnectionFromEnv
# =============================================================================
# Driver: mysql (default) | pgsql | sqlite
# =============================================================================

DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=app
DB_CHARSET=utf8mb4

# -----------------------------------------------------------------------------
# Read replicas (optional, requires jardisadapter/dbconnection for the pool;
# without the adapter installed, a single plain PDO on DB_HOST is used).
# -----------------------------------------------------------------------------
#DB_READER1_HOST=replica1.internal
#DB_READER1_PORT=3306
#DB_READER1_USER=root
#DB_READER1_PASSWORD=
#DB_READER1_DATABASE=app
#DB_READER2_HOST=replica2.internal

# -----------------------------------------------------------------------------
# SQLite (overrides everything above)
# -----------------------------------------------------------------------------
#DB_DRIVER=sqlite
#DB_PATH=:memory:

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
#DB_DRIVER=pgsql
#DB_PORT=5432
