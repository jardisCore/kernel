{
    "name": "jardiscore/domain",
    "description": "DDD Domain Core for PHP — BoundedContext, ContextResult, DomainResponse, DomainKernel",
    "type": "library",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "jardisport/domain": "^1.0",
        "jardisport/classversion": "^1.0",
        "psr/container": "^2.0",
        "psr/log": "^3.0",
        "psr/simple-cache": "^3.0",
        "psr/event-dispatcher": "^1.0",
        "psr/http-client": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2 || ^4.0.0"
    },
    "autoload": {
        "psr-4": {
            "JardisCore\\Domain\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisCore\\Domain\\Tests\\": "tests/"
        }
    },
    "homepage": "https://github.com/jardisCore/domain",
    "support": {
        "issues": "https://github.com/jardisCore/domain/issues",
        "email": "jardisCore@headgent.dev"
    },
    "keywords": [
        "domain",
        "kernel",
        "bounded-context",
        "ddd",
        "JardisCore",
        "Headgent"
    ]
}
